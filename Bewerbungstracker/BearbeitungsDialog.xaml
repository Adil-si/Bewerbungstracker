<Window x:Class="Bewerbungstracker.BearbeitungsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="✏️ Bewerbung bearbeiten" 
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Firma -->
        <Label Grid.Row="0" Grid.Column="0" Content="Firma:" FontWeight="Bold"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtFirma" Height="30" Margin="0,0,0,10"/>

        <!-- Plattform -->
        <Label Grid.Row="1" Grid.Column="0" Content="Plattform:" FontWeight="Bold"/>
        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbPlattform" Height="30" Margin="0,0,0,10">
            <ComboBoxItem Content="LinkedIn"/>
            <ComboBoxItem Content="Indeed"/>
            <ComboBoxItem Content="Xing"/>
            <ComboBoxItem Content="StepStone"/>
            <ComboBoxItem Content="Direkt"/>
            <ComboBoxItem Content="Andere"/>
        </ComboBox>

        <!-- Datum -->
        <Label Grid.Row="2" Grid.Column="0" Content="Datum:" FontWeight="Bold"/>
        <DatePicker Grid.Row="2" Grid.Column="1" x:Name="dpDatum" Height="30" Margin="0,0,0,10"/>

        <!-- Status -->
        <Label Grid.Row="3" Grid.Column="0" Content="Status:" FontWeight="Bold"/>
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cbStatus" Height="30" Margin="0,0,0,10">
            <ComboBoxItem Content="📧 Beworben"/>
            <ComboBoxItem Content="⏳ Warte auf Rückmeldung"/>
            <ComboBoxItem Content="📞 Telefonische Anfrage"/>
            <ComboBoxItem Content="✅ Einladung zum Gespräch"/>
            <ComboBoxItem Content="🎉 Zusage bekommen"/>
            <ComboBoxItem Content="❌ Absage"/>
        </ComboBox>

        <!-- Website -->
        <Label Grid.Row="4" Grid.Column="0" Content="Website:" FontWeight="Bold"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtWebsite" Height="30" Margin="0,0,0,10"/>

        <!-- Ansprechpartner -->
        <Label Grid.Row="5" Grid.Column="0" Content="Ansprechpartner:" FontWeight="Bold"/>
        <TextBox Grid.Row="5" Grid.Column="1" x:Name="txtAnsprechpartner" Height="30" Margin="0,0,0,10"/>

        <!-- Telefon -->
        <Label Grid.Row="6" Grid.Column="0" Content="Telefon:" FontWeight="Bold"/>
        <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtTelefon" Height="30" Margin="0,0,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="💾 Speichern" Width="100" Height="35" Margin="5" Click="BtnSpeichern_Click"/>
            <Button Content="❌ Abbrechen" Width="100" Height="35" Margin="5" Click="BtnAbbrechen_Click"/>
        </StackPanel>
    </Grid>
</Window>