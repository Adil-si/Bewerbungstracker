<Window x:Class="Bewerbungstracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:Bewerbungstracker"
        mc:Ignorable="d"
        Title=" SI Bewerbungstracker - Praktikum" 
        Height="850" Width="950"
        MinHeight="650" MinWidth="750"
        WindowStartupLocation="CenterScreen">

    <!-- ScrollViewer für das gesamte Fenster -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 0: Titel -->
                <RowDefinition Height="Auto"/>
                <!-- 1: Eingabe -->
                <RowDefinition Height="Auto"/>
                <!-- 2: Filter -->
                <RowDefinition Height="Auto"/>
                <!-- 3: Aktive Box -->
                <RowDefinition Height="Auto"/>
                <!-- 4: Absagen Box -->
                <RowDefinition Height="Auto"/>
                <!-- 5: Statusleiste -->
            </Grid.RowDefinitions>

            <!-- Titel -->
            <TextBlock Grid.Row="0" Text="📋 Meine Bewerbungen" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>

            <!-- Eingabebereich -->
            <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Padding="10" CornerRadius="8" Margin="0,0,0,15">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- 0: Firma -->
                            <RowDefinition Height="Auto"/>
                            <!-- 1: Status -->
                            <RowDefinition Height="Auto"/>
                            <!-- 2: Adresse & PLZ -->
                            <RowDefinition Height="Auto"/>
                            <!-- 3: Plattform -->
                            <RowDefinition Height="Auto"/>
                            <!-- 4: Datum -->
                            <RowDefinition Height="Auto"/>
                            <!-- 5: Website -->
                            <RowDefinition Height="Auto"/>
                            <!-- 6: Ansprechpartner -->
                            <RowDefinition Height="Auto"/>
                            <!-- 7: Telefon -->
                            <RowDefinition Height="Auto"/>
                            <!-- 8: Buttons -->
                        </Grid.RowDefinitions>

                        <!-- Firma -->
                        <Label Grid.Row="0" Grid.Column="0" Content="Firma:" FontWeight="Bold"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtFirma" Height="30" Margin="0,0,0,10"/>

                        <!-- Status -->
                        <Label Grid.Row="1" Grid.Column="0" Content="Status:" FontWeight="Bold"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbStatus" Height="30" Margin="0,0,0,10">
                            <ComboBoxItem Content="📧 Beworben"/>
                            <ComboBoxItem Content="⏳ Warte auf Rückmeldung"/>
                            <ComboBoxItem Content="📞 Telefonische Anfrage"/>
                            <ComboBoxItem Content="✅ Einladung zum Gespräch"/>
                            <ComboBoxItem Content="🎉 Zusage bekommen"/>
                            <ComboBoxItem Content="❌ Absage"/>
                            <ComboBoxItem Content="📌 Potenzielle Firma für zukünftige Bewerbung"/>
                        </ComboBox>

                        <!-- Adresse & PLZ -->
                        <Label Grid.Row="2" Grid.Column="0" Content="Adresse &amp; PLZ:" FontWeight="Bold"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtAdresse" Height="30" Margin="0,0,0,10" 
                                 ToolTip="Optional - z.B. Musterstraße 123, 12345 Berlin"/>

                        <!-- Plattform -->
                        <Label Grid.Row="3" Grid.Column="0" Content="Plattform:" FontWeight="Bold"/>
                        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cbPlattform" Height="30" Margin="0,0,0,10">
                            <ComboBoxItem Content="LinkedIn"/>
                            <ComboBoxItem Content="Indeed"/>
                            <ComboBoxItem Content="Xing"/>
                            <ComboBoxItem Content="StepStone"/>
                            <ComboBoxItem Content="Direkt"/>
                            <ComboBoxItem Content="Andere"/>
                        </ComboBox>

                        <!-- Datum -->
                        <Label Grid.Row="4" Grid.Column="0" Content="Datum:" FontWeight="Bold"/>
                        <DatePicker Grid.Row="4" Grid.Column="1" x:Name="dpDatum" SelectedDate="2026-04-17" Margin="0,0,0,10"/>

                        <!-- Firmen-Website -->
                        <Label Grid.Row="5" Grid.Column="0" Content="Firmen-Website:" FontWeight="Bold"/>
                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="txtWebsite" Height="30" Margin="0,0,0,10"/>

                        <!-- Ansprechpartner -->
                        <Label Grid.Row="6" Grid.Column="0" Content="Ansprechpartner:" FontWeight="Bold"/>
                        <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtAnsprechpartner" Height="30" Margin="0,0,0,10"/>

                        <!-- Telefon -->
                        <Label Grid.Row="7" Grid.Column="0" Content="Telefon:" FontWeight="Bold"/>
                        <TextBox Grid.Row="7" Grid.Column="1" x:Name="txtTelefon" Height="30" Margin="0,0,0,10"/>

                        <!-- Buttons -->
                        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <Button x:Name="btnPruefen" Content="🔍 Firma prüfen" Width="120" Height="35" Margin="5" Click="BtnPruefen_Click"/>
                            <Button x:Name="btnSpeichern" Content="💾 Bewerbung speichern" Width="140" Height="35" Margin="5" Click="BtnSpeichern_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- FILTER-Bereich -->
            <Border Grid.Row="2" BorderBrush="LightBlue" BorderThickness="1" Padding="8" CornerRadius="8" Margin="0,0,0,10" Background="#F0F8FF">
                <StackPanel>
                    <TextBlock Text="🔍 Filter für aktive Bewerbungen" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Zeile 0: Datum Filter + Status Filter -->
                        <Label Grid.Row="0" Grid.Column="0" Content="Datum:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cbDatumFilter" Width="140" Height="28" Margin="0,0,15,0" SelectionChanged="Filter_Changed">
                            <ComboBoxItem Content="Alle" IsSelected="True"/>
                            <ComboBoxItem Content="Letzte 7 Tage"/>
                            <ComboBoxItem Content="Letzte 30 Tage"/>
                            <ComboBoxItem Content="Letzte 90 Tage"/>
                            <ComboBoxItem Content="Letztes Jahr"/>
                        </ComboBox>

                        <Label Grid.Row="0" Grid.Column="2" Content="Status:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox Grid.Row="0" Grid.Column="3" x:Name="cbStatusFilter" Width="180" Height="28" Margin="0,0,15,0" SelectionChanged="Filter_Changed">
                            <ComboBoxItem Content="Alle Status" IsSelected="True"/>
                            <ComboBoxItem Content="📧 Beworben"/>
                            <ComboBoxItem Content="⏳ Warte auf Rückmeldung"/>
                            <ComboBoxItem Content="📞 Telefonische Anfrage"/>
                            <ComboBoxItem Content="✅ Einladung zum Gespräch"/>
                            <ComboBoxItem Content="🎉 Zusage bekommen"/>
                            <ComboBoxItem Content="📌 Potenzielle Firma für zukünftige Bewerbung"/>
                        </ComboBox>

                        <Button Grid.Row="0" Grid.Column="4" x:Name="btnFilterReset" Content="🔄 Zurücksetzen" Width="100" Height="28" Click="BtnFilterReset_Click" Margin="10,0,0,0"/>

                        <!-- Zeile 1: Bestimmtes Datum -->
                        <Label Grid.Row="1" Grid.Column="0" Content="Bestimmtes Datum:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,5,10,0"/>
                        <DatePicker Grid.Row="1" Grid.Column="1" x:Name="dpBestimmtesDatum" Width="120" Height="28" 
                                    SelectedDate="{x:Null}" Margin="0,5,15,0" SelectedDateChanged="Filter_Changed"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Aktive Bewerbungen Box -->
            <Border Grid.Row="3" BorderBrush="Green" BorderThickness="2" Padding="5" CornerRadius="8" Margin="0,0,0,10" Background="#F0FFF0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📋 AKTIVE BEWERBUNGEN (offen / warte / Gespräch / Zusage)" FontWeight="Bold" FontSize="14" Margin="5" Foreground="DarkGreen"/>

                    <ListBox Grid.Row="1" x:Name="lstAktive" 
                             AlternationCount="3"
                             MaxHeight="250" 
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             DisplayMemberPath="DisplayText" 
                             SelectionChanged="LstAktive_SelectionChanged" 
                             MouseDoubleClick="LstAktive_MouseDoubleClick">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                        <Setter Property="Background" Value="#FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="2">
                                        <Setter Property="Background" Value="#FFFFFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Absagen Box -->
            <Border Grid.Row="4" BorderBrush="Red" BorderThickness="2" Padding="5" CornerRadius="8" Margin="0,0,0,10" Background="#FFF0F0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="❌ ABSAGEN (nicht gelöscht - nur archiviert)" FontWeight="Bold" FontSize="14" Margin="5" Foreground="DarkRed"/>

                    <ListBox Grid.Row="1" x:Name="lstAbsagen" 
                             AlternationCount="3"
                             MaxHeight="150" 
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             DisplayMemberPath="DisplayText"
                             SelectionChanged="LstAbsagen_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                        <Setter Property="Background" Value="#FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="2">
                                        <Setter Property="Background" Value="#FFFFFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Statusleiste und Buttons -->
            <StatusBar Grid.Row="5" Margin="0,10,0,0">
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="txtStatus" Text="Bereit" Width="350"/>

                        <Button x:Name="btnBearbeiten" 
                                Content="✏️ Bearbeiten" 
                                Width="100" Height="25" 
                                Margin="5,0,5,0" 
                                Click="BtnBearbeiten_Click" 
                                Visibility="Collapsed"/>

                        <Button x:Name="btnLoeschen" 
                                Content="🗑 Ausgewählte löschen" 
                                Width="150" Height="25" 
                                Margin="5,0,20,0" 
                                Click="BtnLoeschen_Click" 
                                Visibility="Collapsed"/>

                        <Border Background="#F0F0F0" CornerRadius="5" Padding="8,2,8,2" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🐙" FontSize="12" Margin="0,0,5,0"/>
                                <TextBlock>
                                    <Hyperlink NavigateUri="https://github.com/Adil-si/Bewerbungstracker" 
                                               RequestNavigate="Hyperlink_RequestNavigate"
                                               Foreground="#24292F">
                                        GitHub
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="v1.0" Foreground="Gray" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>
        </Grid>

    </ScrollViewer>
</Window>